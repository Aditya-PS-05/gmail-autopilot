# Copy to .env and fill in only what you need.
# Defaults run with mock Gmail and a fake LLM, so no credentials are required.

# --- backends ---
BRACE_GMAIL_BACKEND=mock          # mock | real
BRACE_LLM_BACKEND=fake            # fake | anthropic | openai | grok | auto

# `auto` routes per-task across whichever provider keys are configured.
# Override the default rankings per task type (comma-separated provider names):
# BRACE_LLM_PREFERENCE_FAST=openai,grok,anthropic
# BRACE_LLM_PREFERENCE_SMART=anthropic,openai,grok
# BRACE_LLM_PREFERENCE_CHEAP=grok,openai,anthropic
BRACE_MODE=dry-run                # dry-run | real
BRACE_LIMIT=10
BRACE_DB_PATH=runs.db
BRACE_LOG_LEVEL=INFO

# --- credentials (only fill the ones for the backends you use) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=                      # for Grok (xAI's OpenAI-compatible API)
GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- priority ranking (optional) ---
# Comma-separated. Matches lift emails to the top of the run summary.
COURIER_VIPS=tharun@brace.so,paul@yc.com
COURIER_KEYWORDS=offer,interview,investor,urgent
