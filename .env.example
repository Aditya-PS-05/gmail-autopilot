# Copy to .env and fill in only what you need.
# Defaults run with mock Gmail and a fake LLM, so no credentials are required.

# --- backends ---
BRACE_GMAIL_BACKEND=mock          # mock | real
BRACE_LLM_BACKEND=fake            # fake | anthropic
BRACE_MODE=dry-run                # dry-run | real
BRACE_LIMIT=10
BRACE_DB_PATH=runs.db
BRACE_LOG_LEVEL=INFO

# --- credentials (only needed for real backends) ---
ANTHROPIC_API_KEY=
GOOGLE_CREDENTIALS_PATH=./credentials.json
